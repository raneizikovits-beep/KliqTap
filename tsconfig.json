// client/tsconfig.json
{



  // ירושה מהגדרות הבסיס של אקספו
  "extends": "expo/tsconfig.base", 
  
  "compilerOptions": {
    // 1. **פתרון ל-api.js**: חובה לאפשר ייבוא קבצי JavaScript
    "allowJs": true, 
    "ignoreDeprecations": "6.0",

    // 2. **פתרון ל-socket.io-client**: מבטיח שהקומפיילר מוצא חבילות ב-node_modules
    "moduleResolution": "node", 
    
    // 3. משפר את התאימות בין מודולים
    "esModuleInterop": true,
    
    // 4. ודא שאתה משתמש בגרסאות מודרניות
    "target": "ES2020",
    "module": "commonjs", 
    
    // 5. הגדרות נקיות לפרויקט לקוח (מומלץ)
    "strict": true,
    "skipLibCheck": true 
  },
  
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx"
  ]
}